ENVIRONMENT=production

# Neon Postgres — use the "pooled" connection string from your Neon project.
# postgres:// or postgresql:// both work; the app normalizes it for asyncpg.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname

REDIS_URL=redis://localhost:6379/0

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-string
PUBLIC_BASE_URL=https://your-app.fastapicloud.dev

GITHUB_TOKEN=ghp_your_token_with_repo_dispatch_scope
GITHUB_REPO_OWNER=sambathreasmey
GITHUB_REPO_NAME=po-generate-automation
ALERT_CHAT_ID=

# Shared secret the po-generate-automation workflow must send back
# (as the X-Callback-Secret header) when calling POST /api/po/callback.
PO_CALLBACK_SECRET=change-me-to-another-random-string

# Telegram Mini App URL — same host as PUBLIC_BASE_URL, served at /app.
MINI_APP_URL=https://your-app.fastapicloud.dev/app
